{
  "policy": "project_theseus_open_code_training_pantry_expanded_v0",
  "purpose": "Curated permissive open-source repositories for train-only code expression pressure. Public benchmark repositories and benchmark-named paths remain excluded by the pantry script.",
  "defaults": {
    "max_repos": 36,
    "max_files_per_repo": 700,
    "max_bytes_per_file": 220000,
    "max_expressions": 5000,
    "max_full_body_functions": 5000
  },
  "usage_policy": {
    "training_role": "private open-code pressure only",
    "public_benchmark_evidence": false,
    "candidate_bank_eligible_by_default": false,
    "license_gate": "GitHub SPDX must be in the script allowlist before admission",
    "skip_on_license_unknown": true,
    "skip_on_benchmark_name": true
  },
  "repos": [
    {"repo": "psf/requests", "why": "HTTP client, Apache-2.0, compact Python idioms"},
    {"repo": "pallets/click", "why": "CLI parsing, BSD-3-Clause"},
    {"repo": "pallets/flask", "why": "web framework patterns, BSD-3-Clause"},
    {"repo": "pallets/werkzeug", "why": "WSGI and HTTP utilities, BSD-3-Clause"},
    {"repo": "pallets/jinja", "why": "templating/string logic, BSD-3-Clause"},
    {"repo": "pytest-dev/pluggy", "why": "plugin dispatch patterns, MIT"},
    {"repo": "python-attrs/attrs", "why": "data model helpers, MIT"},
    {"repo": "encode/httpx", "why": "HTTP client/control flow, BSD-3-Clause"},
    {"repo": "encode/starlette", "why": "ASGI utilities, BSD-3-Clause"},
    {"repo": "fastapi/fastapi", "why": "typed API patterns, MIT"},
    {"repo": "pydantic/pydantic", "why": "validation and type-shape logic, MIT"},
    {"repo": "Textualize/rich", "why": "formatting/table/tree logic, MIT"},
    {"repo": "Textualize/textual", "why": "stateful UI/event patterns, MIT"},
    {"repo": "scrapy/scrapy", "why": "crawler/parsing/control-flow patterns, BSD-3-Clause"},
    {"repo": "aio-libs/aiohttp", "why": "async network/control-flow patterns, Apache-2.0"},
    {"repo": "ipython/ipython", "why": "interactive shell/tooling patterns, BSD-3-Clause"},
    {"repo": "prompt-toolkit/python-prompt-toolkit", "why": "interactive terminal/input logic, BSD-3-Clause"},
    {"repo": "numpy/numpy", "why": "array utilities and numeric helper idioms, BSD-3-Clause"},
    {"repo": "pandas-dev/pandas", "why": "data-frame/list/selection logic, BSD-3-Clause"},
    {"repo": "scipy/scipy", "why": "scientific numeric utilities, BSD-3-Clause"},
    {"repo": "scikit-learn/scikit-learn", "why": "ML utilities, BSD-3-Clause"},
    {"repo": "sympy/sympy", "why": "symbolic/numeric transformations, BSD-3-Clause"},
    {"repo": "networkx/networkx", "why": "graph algorithms, BSD-3-Clause"},
    {"repo": "pydata/xarray", "why": "labeled-array utilities, Apache-2.0"},
    {"repo": "mwaskom/seaborn", "why": "data visualization helpers, BSD-3-Clause"},
    {"repo": "jupyterlab/jupyterlab", "why": "application/workspace code, BSD-3-Clause"},
    {"repo": "jupyter/notebook", "why": "server/UI integration code, BSD-3-Clause"},
    {"repo": "jupyter-server/jupyter_server", "why": "server routing and config logic, BSD-3-Clause"},
    {"repo": "plotly/dash", "why": "web app callback logic, MIT"},
    {"repo": "python-poetry/poetry", "why": "dependency/tool workflow code, MIT"},
    {"repo": "pypa/pip", "why": "package/tooling logic, MIT"},
    {"repo": "celery/celery", "why": "distributed task queue patterns, BSD-3-Clause"},
    {"repo": "home-assistant/core", "why": "large real-world automation code, Apache-2.0"},
