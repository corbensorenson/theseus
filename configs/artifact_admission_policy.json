{
  "policy": "project_theseus_artifact_admission_policy_v1",
  "purpose": "local_private_model_runtime",
  "max_advisory_age_hours": 24,
  "trusted_public_keys": {},
  "revoked_key_ids": [],
  "revoked_artifact_hashes": [],
  "minimum_generation_by_artifact": {},
