      "material_available": true,
      "material_withheld": true,
      "denial_or_redaction_reason": "fork cannot transfer public benchmark payloads, raw private text, secrets, or unsafe authority",
      "access_path": "AGENTS.md",
      "appeal_path": "configs/project_steward.json",
      "preservation_obligation": "record denial scope, reason, authority, and appeal path",
      "safety_obligations_transferable": false
    }
  ],
