{
  "policy": "project_theseus_resource_pantry_v0",
  "enabled": true,
  "role": "durable_open_source_benchmark_and_rl_resource_shelf",
  "default_mode": "shallow_clone_open_license_sources_metadata_only_for_data",
  "storage": {
    "preferred_clone_root": "resource_pantry/git",
    "fallback_clone_root": "data/external_benchmark_candidates/git_clones",
    "metadata_root": "data/external_benchmark_candidates/resource_pantry_metadata",
    "min_free_gib_preferred": 100,
    "min_free_gib_fallback": 25
  },
  "clone_policy": {
    "max_clones_per_run": 24,
    "shallow_depth": 1,
    "filter_blob_none": true,
    "update_existing": false,
    "allow_submodules": false,
    "allowed_code_licenses": [
      "apache-2.0",
      "mit",
      "bsd-2-clause",
      "bsd-3-clause",
      "mpl-2.0",
      "cc0-1.0",
      "unlicense"
    ],
    "blocked_categories": [
      "training_data",
      "voice_training_data",
      "voice_benchmark_data"
    ],
    "metadata_only_categories": [
      "training_data",
      "voice_training_data",
      "voice_benchmark_data"
    ],
    "rom_or_game_asset_policy": "never_download_roms_or_commercial_game_assets",
    "high_risk_runtime_policy": "clone_source_only; require sandbox/adapter smoke before execution",
    "exclude_non_permissive_or_uncleared_sources": true
  },
  "priority_source_ids": [
    "gymnasium",
    "minigrid",
    "bsuite",
    "craftax",
    "crafter",
    "minerl",
    "minedojo",
    "malmo",
    "voyager_minecraft",
    "procgen",
    "pettingzoo",
    "pyflyt",
    "gym_pybullet_drones",
    "airsim_drone_racing_lab",
    "mavsdk_python",
    "aerial_gym_simulator",
    "airsim",
    "px4_sitl",
    "pygba",
    "mgba",
    "metaworld",
    "lm_eval_harness",
    "simple_evals",
    "evalplus",
    "bigcodebench",
    "livecodebench",
    "inspect_evals",
    "mini_swe_agent",
    "swe_agent",
    "swe_rex",
    "swe_smith",
    "swe_gen",
    "opencode",
    "opencode_bench",
    "openhands",
    "terminal_bench",
    "bfcl",
    "tau2_bench",
    "tau_bench",
    "browsergym",
    "webarena",
    "osworld",
    "the_agent_company",
    "swe_skills_bench",
    "codeclash",
    "swe_atlas",
    "swe_polybench",
    "repobench",
    "repo_trans_bench",
    "swelancer",
    "apps",
    "code_contests",
    "the_stack_v2",
    "starcoderdata",
    "codesearchnet",
    "jumanji",
    "brax",
    "dm_control",
    "envpool",
    "human_eval",
    "hendrycks_test"
  ],
  "readiness_checks": {
    "require_license_file_hint": false,
    "require_readme_or_docs_hint": true,
    "require_adapter_plan": true,
    "write_markdown_report": true
  },
  "safety": {
    "external_inference_calls": 0,
    "bulk_training_data_downloads": false,
    "commercial_rom_downloads": false,
    "arbitrary_code_execution": false,
    "autonomous_use_requires_adapter_card": true
  }
}
