{
  "policy": "project_theseus_code_residual_forge_policy_v1",
  "purpose": "Turn every code frontier run into classified residuals, repair traces, transfer artifacts, and same-family rotation pressure before any model growth.",
  "family": "coding_local_sandbox",
  "floor_threshold": 0.7,
  "below_floor_attempts_before_rotate": 2,
  "stalled_cycles_before_rotate": 2,
  "ordered_card_ids": [
    "source_bigcodebench",
    "source_evalplus",
    "source_human_eval",
    "source_mbpp",
    "source_livecodebench",
    "source_opencode",
    "source_swe_bench",
    "source_swe_agent",
    "source_mini_swe_agent",
    "source_codeclash",
    "source_swe_polybench",
    "source_swe_gen",
    "old_registry_benchmark_corben_coding_agent_native_v1",
    "old_registry_benchmark_corben_task_execution_native_v1"
  ],
  "residual_taxonomy": [
    "parsing",
    "edge_case",
    "algorithm_choice",
    "type_handling",
    "hidden_tests",
    "repair_loop",
    "tool_use_failure",
    "timeout",
    "dependency_issue",
    "benchmark_integrity",
    "mastered_needs_diversity"
  ],
  "required_outputs": [
