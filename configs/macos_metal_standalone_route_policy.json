{
  "policy": "project_theseus_macos_metal_standalone_route_policy_v0",
  "purpose": "Declare the approved bounded local production route contract for train-standalone-metal.",
  "command": "train-standalone-metal",
  "parity_for": "train-standalone-cuda",
  "backend": "apple_metal",
  "route_state": "approved_bounded_local_production",
  "bounded_canary_route_enabled": true,
