  "jobs": {
    "enabled": true,
    "model": "arm_aware_embarrassingly_parallel_v0",
    "scheduler_report_path": "reports/hive_jobs.json",
    "defaults": {
      "priority": 50,
      "lease_seconds": 1800,
      "max_retries": 1,
      "merge_policy": "append_report_then_candidate_gate"
    },
    "defaults_by_task_kind": {
      "cuda_eval_chunk": {
        "arm_id": "rust_cuda_systems_arm",
        "priority": 70,
        "merge_policy": "append_cuda_eval_report"
      },
      "cuda_training_chunk": {
        "arm_id": "rust_cuda_systems_arm",
        "priority": 80,
        "merge_policy": "merge_readout_candidate_if_gate_passes"
      },
      "cuda_rollout_chunk": {
        "arm_id": "rl_control_arm",
        "priority": 78,
        "merge_policy": "merge_rollout_candidate_if_probe_improves"
      },
      "mlx_eval_chunk": {
        "arm_id": "apple_mlx_worker_arm",
        "priority": 65,
        "merge_policy": "append_mlx_eval_report"
      },
      "mlx_training_chunk": {
        "arm_id": "apple_mlx_worker_arm",
        "priority": 72,
        "merge_policy": "merge_mlx_readout_candidate_if_gate_passes"
      },
      "mlx_rollout_chunk": {
        "arm_id": "apple_mlx_control_arm",
        "priority": 76,
        "merge_policy": "merge_mlx_rollout_candidate_if_probe_improves"
      }
    },
    "embarrassingly_parallel": {
      "enabled": true,
      "max_jobs_per_cuda_node": 3,
      "max_jobs_per_mlx_node": 3,
      "max_jobs_per_cpu_node": 2,
      "families": [
        "seed_sweep",
        "eval_shard",
        "readout_chunk",
        "rollout_chunk",
        "hyperparameter_probe"
      ]
    }
  },
  "artifact_sync": {
    "enabled": true,
    "inbox_path": "reports/hive_artifact_inbox",
    "ledger_path": "reports/hive_artifact_sync_ledger.jsonl",
