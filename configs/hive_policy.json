{
  "policy": "project_theseus_hive_policy_v0",
  "enabled": true,
  "purpose": "Turn Project Theseus machines on the same trusted network into a resource-aware hive for local training, evaluation, inference routing, and operator chat surfaces.",
  "node": {
    "default_role": [
      "coordinator",
      "worker",
      "chat_gateway"
    ],
    "http_host": "0.0.0.0",
    "http_port": 8791,
    "dashboard_port": 8787,
    "heartbeat_interval_seconds": 5,
    "stale_after_seconds": 45,
    "task_submit_timeout_seconds": 30,
    "identity_path": "reports/hive_node_identity.json",
    "status_path": "reports/hive_status.json",
    "peers_path": "reports/hive_peers.json",
    "task_ledger_path": "reports/hive_task_ledger.jsonl",
    "task_queue_path": "reports/hive_task_queue.jsonl",
    "job_ledger_path": "reports/hive_job_ledger.jsonl",
    "registry_operator_status_enabled": false,
    "registry_operator_status_timeout_seconds": 1.0
  },
  "discovery": {
    "enabled": true,
    "lan_scope": "same_subnet_only",
    "multicast_group": "239.255.87.87",
    "multicast_port": 8789,
    "ttl": 1,
    "bind_host": "0.0.0.0",
    "announce_prefix": "project-theseus-hive",
    "peer_registry_path": "reports/hive_peer_registry.json",
    "max_known_peers": 256,
    "peer_retention_seconds": 604800,
    "probe_known_peers": true,
    "known_peer_probe_interval_seconds": 30,
    "coordinator_sync_timeout_seconds": 8,
    "peer_probe_timeout_seconds": 3,
    "bonjour_enabled": true,
    "bonjour_service_type": "_theseus-hive._tcp",
    "bonjour_domain": "local.",
    "bonjour_browse_seconds": 3,
    "bonjour_advertise_refresh_seconds": 300,
    "require_signed_multicast_when_secret_configured": true,
    "require_signed_multicast": false,
    "trust_unsigned_multicast_without_secret": true
  },
  "federation": {
    "tiers": {
      "private": {
        "description": "Your own machines across home, workshop, phones, and private tunnels.",
        "remote_tasks": true,
        "training_tasks": true,
        "inference_tasks": true,
        "requires_invite": true,
        "requires_shared_secret": true
      },
      "friends_family": {
        "description": "Known people or a company/workgroup sharing compute by invitation.",
        "remote_tasks": true,
        "training_tasks": false,
        "inference_tasks": true,
        "requires_invite": true,
        "requires_shared_secret": true,
        "default_task_scope": [
          "resource_probe",
          "capability_refresh",
          "checkpoint_chat"
        ]
      },
      "company": {
        "description": "Licensed company or organization Hive. Requires a signed paid Project Theseus license before company-scope joining or worker chunks are allowed.",
        "remote_tasks": true,
        "training_tasks": true,
        "inference_tasks": true,
        "requires_invite": true,
        "requires_shared_secret": true,
        "requires_feature": "company_hive"
      },
      "public": {
        "description": "Open compute network. Public contribution is opt-in and worker-only until signed tasks, sandboxing, reputation, abuse controls, and legal terms exist.",
        "remote_tasks": false,
        "training_tasks": false,
        "inference_tasks": false,
        "requires_invite": true,
        "requires_shared_secret": true,
        "status": "worker_contribution_scaffold_only"
      }
    },
    "default_tier": "private",
    "join_config_path": "configs/hive_join.local.json",
    "profiles_path": "configs/hive_profiles.local.json",
    "hive_id_env": "THESEUS_HIVE_ID",
    "relay_url_env": "THESEUS_HIVE_RELAY_URL",
    "node_tags_env": "THESEUS_HIVE_NODE_TAGS"
  },
  "setup_wizard": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 8788,
    "launcher_windows": "bin/project-theseus-setup.cmd",
    "launcher_macos": "bin/project-theseus-setup.command",
    "supports_profile_switching": true,
    "supports_phone_qr": true,
    "public_hive_visible_but_disabled": true
  },
  "public_contribution": {
    "purpose": "Allow a private or semi-private Hive node to donate idle compute to the larger public Theseus Hive without exposing private data, private peers, teacher/self-edit capability, or arbitrary shell.",
    "config_path": "configs/public_hive.local.json",
    "status_path": "reports/public_hive_contribution_status.json",
    "ledger_path": "reports/public_hive_contribution_ledger.jsonl",
    "default_mode": "off",
    "modes": {
      "off": "Never connect to the public Hive.",
      "idle": "Offer bounded public compute only when the machine is idle and resource gates are green.",
      "always": "Offer bounded public compute whenever resource gates are green."
    },
    "gateway_url": "",
    "public_hive_id": "theseus-public",
    "require_explicit_opt_in": true,
    "require_signed_task_manifest": true,
    "worker_only": true,
    "never_share": [
      "private_hive_join_tokens",
      "private_hive_peer_lists",
      "local_training_data",
      "rom_assets",
      "checkpoint_weights_unless_user_publishes_them",
      "teacher_oracle",
      "teacher_self_edit",
      "git_credentials",
      "arbitrary_filesystem"
    ],
    "allowed_public_task_kinds": [
      "resource_probe",
      "capability_refresh",
      "public_training_smoke",
      "public_eval_shard",
      "public_synthetic_quality_vote"
    ],
    "idle_policy": {
      "idle_minutes_before_connect": 20,
      "allow_on_ac_power_only": true,
      "min_disk_free_gib": 25,
      "max_memory_load_percent": 82,
      "max_gpu_utilization_percent": 35,
      "max_gpu_memory_used_percent": 70,
      "max_cpu_load_percent": 65
    },
    "budgets": {
      "max_public_gpu_memory_fraction": 0.65,
      "max_public_cpu_threads_fraction": 0.5,
      "max_public_disk_cache_gib": 25,
      "max_task_runtime_seconds": 1800,
      "max_download_mb_per_day": 512,
      "max_upload_mb_per_day": 512
    },
    "promotion_requirements": [
      "signed_native_worker",
      "task_manifest_signature_verification",
      "sandboxed_execution_runtime",
      "public_task_reputation",
      "resource_quota_enforcement",
      "user_visible_pause_stop",
      "privacy_boundary_tests",
      "legal_terms_and_abuse_response"
    ]
  },
  "rented_compute": {
    "enabled": true,
    "purpose": "Make it easy to add rented compute or storage to a private Hive while preserving dry-run planning, explicit cost approval, public-data leakage controls, and provider portability.",
    "local_config_path": "configs/hive_rented_compute.local.json",
    "status_path": "reports/hive_rented_compute_status.json",
    "plan_path": "reports/hive_rented_compute_plan.json",
    "launch_path": "reports/hive_rented_compute_launch.json",
    "ledger_path": "reports/hive_rented_compute_ledger.jsonl",
    "default_provider": "aws_ec2",
    "dry_run_default": true,
    "execute_requires_operator_flag": true,
    "allowed_task_kinds": [
      "cuda_eval_chunk",
      "cuda_training_chunk",
      "cuda_rollout_chunk",
      "training_smoke",
      "mlx_eval_chunk",
      "mlx_training_chunk",
      "mlx_rollout_chunk",
      "storage_burst",
      "artifact_sync",
      "checkpoint_handoff"
    ],
    "provider_maturity": {
      "aws_ec2": "R2_sandboxed_cloud_launch_adapter",
      "aws_s3": "R1_planning_adapter_with_explicit_execute",
      "gcp_compute": "R2_sandboxed_cloud_launch_adapter",
      "gcp_gcs": "R1_planning_adapter_with_explicit_execute",
      "azure_vm": "R2_sandboxed_cloud_launch_adapter",
      "azure_blob": "R1_planning_adapter_with_explicit_execute",
      "runpod": "R1_api_launch_adapter_requires_profile_review",
      "vast_ai": "R1_cli_launch_adapter_requires_offer_review",
      "lambda_cloud": "R0_contract_only",
      "coreweave": "R0_contract_only",
      "fluidstack": "R0_contract_only",
      "ssh_gpu_host": "R0_contract_only"
    },
    "default_conditions": {
      "spot_only": true,
      "max_session_hours": 6,
      "max_estimated_hourly_usd": 0.75,
      "max_total_usd_per_session": 4.5,
      "max_daily_planned_usd": 12.0,
      "max_weekly_planned_usd": 48.0,
      "cooldown_minutes": 20,
      "require_queue_pressure": true,
      "require_broad_transfer_below_floor": true,
      "min_transfer_floor_gap": 0.03,
      "min_local_disk_free_gib": 10,
      "require_services": [
        "hive_node"
      ],
      "stop_when_queue_empty": true,
      "stop_when_budget_spent": true
    },
    "user_policies": {
      "overnight_spot_gpu": {
        "description": "Default safe burst policy for GPU learning pressure: spot only, nights/weekends, bounded spend, and only when transfer/queue pressure exists.",
        "time_windows": [
          {
            "days": [
              "mon",
              "tue",
              "wed",
              "thu",
              "sun"
            ],
            "start_local": "21:00",
            "end_local": "07:00"
          },
          {
            "days": [
              "fri",
              "sat"
            ],
            "start_local": "00:00",
            "end_local": "23:59"
          }
        ],
        "spot_only": true,
        "max_session_hours": 6,
        "max_estimated_hourly_usd": 0.75,
        "max_total_usd_per_session": 4.5,
        "max_daily_planned_usd": 12.0,
        "max_weekly_planned_usd": 48.0,
        "cooldown_minutes": 20,
        "require_queue_pressure": true,
        "require_broad_transfer_below_floor": true,
        "min_transfer_floor_gap": 0.03,
        "min_local_disk_free_gib": 10,
        "require_services": [
          "hive_node"
        ]
      },
      "manual_daytime_gpu": {
        "description": "Operator-reviewed daytime burst policy with smaller sessions and explicit launch still required.",
        "spot_only": true,
        "max_session_hours": 2,
        "max_estimated_hourly_usd": 1.25,
        "max_total_usd_per_session": 2.5,
        "max_daily_planned_usd": 8.0,
        "cooldown_minutes": 30,
        "require_queue_pressure": true,
        "require_broad_transfer_below_floor": true,
        "min_local_disk_free_gib": 10,
        "require_services": [
          "hive_node"
        ]
      },
      "storage_burst": {
        "description": "Low-cost object storage expansion for artifact/checkpoint handoff. Creates storage only; upload remains governed by Hive artifact sync.",
        "spot_only": false,
        "max_session_hours": 24,
        "max_estimated_hourly_usd": 0.05,
        "max_total_usd_per_session": 2.0,
        "max_weekly_planned_usd": 8.0,
        "require_queue_pressure": false,
        "require_broad_transfer_below_floor": false,
        "require_services": [],
        "min_local_disk_free_gib": 5
      }
    },
    "safety": {
      "never_store_cloud_credentials_in_repo": true,
      "never_train_on_public_benchmark_solutions": true,
      "never_launch_without_plan_report": true,
      "never_launch_without_execute_flag": true,
      "prefer_private_subnet_or_private_relay": true,
      "never_expose_dashboard_or_hive_api_publicly": [
        8787,
        8791
      ],
      "cloud_init_user_data_may_contain_hive_invite": "ignored_reports_only; treat as secret when include_join_token_in_user_data=true"
    }
  },
  "relay": {
    "enabled_when_configured": true,
    "server_host": "0.0.0.0",
    "server_port": 8793,
    "state_path": "reports/hive_relay_state.json",
    "status_path": "reports/hive_relay_status.json",
    "poll_interval_seconds": 5,
    "task_ttl_seconds": 3600,
    "node_stale_after_seconds": 90,
    "max_payload_bytes": 3145728,
    "mobile_operator_ui": true,
    "chat_task_kind": "checkpoint_chat",
    "allowed_remote_task_kinds_by_tier": {
      "private": [
        "resource_probe",
        "capability_refresh",
        "readiness_check",
        "checkpoint_chat",
