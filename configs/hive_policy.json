  "hive_utilization": {
    "enabled": true,
    "purpose": "Keep every safe private Hive node fed with user work first, then bounded decentralized training, then CPU self-improvement/maintenance, then grounded checkpointing instead of letting compute sit idle.",
    "always_active_mode": "user_work_first_bounded_self_improvement",
    "status_path": "reports/hive_utilization_manager.json",
    "ledger_path": "reports/hive_utilization_ledger.jsonl",
    "training_enabled": true,
    "maintenance_enabled": true,
    "inference_keepalive_enabled": true,
    "training_profile": "inner_loop",
    "adaptive_accelerator_profile": true,
    "min_accelerator_profile": "inner_loop",
    "max_accelerator_profile": "candidate",
    "suppress_cpu_maintenance_when_accelerator_underfed": true,
    "target_queue_depth_per_accelerator_slot": 2,
    "max_new_jobs_per_sweep": 4,
    "accelerator_lease_seconds": 900,
    "max_background_queue_depth_per_node": 2,
    "sweep_interval_seconds": 60,
    "min_disk_free_gib": 5,
    "min_training_disk_free_gib": 8,
    "max_memory_load_percent": 92,
    "allow_on_battery": false,
    "min_battery_percent": 40,
    "max_gpu_utilization_percent_to_enqueue": 85,
    "max_gpu_memory_used_percent_to_enqueue": 88,
    "maintenance_task_order": [
      "training_smoke",
      "storage_index",
      "resource_probe",
      "capability_refresh",
      "network_doctor",
      "voice_following_status",
      "spatial_status",
      "compute_market_status",
      "storage_status",
      "update_status",
      "hive_version_status"
    ],
    "priority_model": [
      {
        "priority": 10,
        "lane": "user_requested_work",
        "rule": "Existing user, operator, storage, voice, and control tasks keep their slots and queue position."
      },
      {
        "priority": 20,
        "lane": "accelerator_training",
        "rule": "Idle CUDA/MLX slots receive bounded decentralized training rounds before lower-value background work."
      },
      {
        "priority": 30,
        "lane": "cpu_self_improvement",
        "rule": "Idle CPU slots rotate bounded smoke training, storage, capability, network, voice, and version refresh tasks."
      },
      {
        "priority": 40,
        "lane": "grounded_checkpoint",
        "rule": "If no safe worker slot is available, keep a grounded checkpoint summary fresh for the operator."
      },
      {
        "priority": 50,
        "lane": "blocked_or_paused",
        "rule": "Stop, pause, resource floors, licensing, and public-data guards beat the no-downtime goal."
      }
    ],
    "rules": {
      "public_benchmarks": "calibration_only_never_training",
      "work_surface": "registered_hive_task_kinds_only",
      "cloud_compute": "never_launch_from_utilization_manager_use_rented_compute_plan_review",
      "teacher": "teacher_is_architecture_diagnosis_only_not_idle_fill"
    }
  },
