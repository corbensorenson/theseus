        "training_smoke",
        "cuda_eval_chunk",
        "cuda_training_chunk",
        "cuda_rollout_chunk",
        "mlx_eval_chunk",
        "mlx_training_chunk",
        "mlx_rollout_chunk",
        "rl_smoke",
        "adapter_smoke"
      ],
      "public": []
    }
  },
  "security": {
    "trust_boundary": "trusted_local_network_private_tunnel_or_authenticated_relay_only",
    "shared_secret_env": "THESEUS_HIVE_SECRET",
    "requires_shared_secret_for_remote_tasks": true,
    "allow_status_without_secret": true,
    "allow_loopback_tasks_without_secret": true,
    "require_signed_task_manifest_for_remote": false,
    "task_manifest_signature_algorithms": [
      "hmac-sha256-private-hive-v0"
    ],
    "revocations_path": "configs/hive_revocations.local.json",
    "quota_state_path": "reports/hive_quota_state.json",
    "quotas": {
      "enabled": true,
      "window_seconds": 3600,
      "max_tasks_per_subject_per_window": 128,
      "max_worker_chunks_per_subject_per_window": 96
    },
    "artifact_signatures": {
      "enabled": true,
      "algorithm": "hmac-sha256-private-hive-v0",
      "sign_task_results": true,
      "sign_worker_reports": true
    },
    "forbidden_remote_task_kinds": [
      "teacher_oracle",
      "teacher_self_edit",
      "git_push",
      "rom_import",
      "bulk_data_download",
      "arbitrary_shell"
    ],
    "remote_mutation_policy": "never_run_arbitrary_commands; only allow registered bounded task kinds"
  },
  "multi_user": {
    "enabled": true,
    "users_config_path": "configs/hive_users.local.json",
    "token_storage": "sha256_hash_only_in_local_ignored_config",
    "legacy_hive_join_token_role": "owner",
    "default_new_user_role": "member",
    "roles": {
