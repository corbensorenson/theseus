        "deterministic_tool_trace",
        "deterministic_tool_artifact_graph",
        "deterministic_tool_dogfood_events",
        "deterministic_tool_loop_closure_candidates"
      ],
      "acceptance_tests": [
        "tool_cards_registered",
        "tool_results_replayable",
        "artifact_graph_and_claim_ledger_present",
        "dogfood_metadata_events_present",
        "loop_closure_candidates_present",
        "no_public_training_rows",
        "no_fallback_returns"
      ],
      "atoms": [
        {
          "id": "load_tool_cards",
          "op": "OBSERVE",
          "title": "Load deterministic tool cards and dependency health",
          "depends_on": [],
          "outputs": [
            "deterministic_tool_registry"
          ],
          "required_capabilities": [
            "registry_lookup",
            "deterministic_tool_card"
          ],
          "allowed_tools": [
            "json_report",
            "registry_lookup"
          ],
          "executor_backend": "local_deterministic_tool",
          "worker_tier": "T0",
          "estimated_seconds": 8,
          "vcm_family": "planning",
