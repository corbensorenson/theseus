{
  "policy": "project_theseus_plan_compiler_v0",
  "purpose": "Compile Theseus goals into typed, VCM-backed, verifier-ready execution DAGs that route through the existing registry, control plane, and Hive work board instead of creating another loose planner.",
  "schema_version": "0.1",
  "source_ideas": [
    "Cognitive Compilation: source plan -> semantic IR -> target compilation",
    "PlanForge: optimized DAG, semantic dedupe, critical path scheduling, watchdog execution",
    "Aletheia Foundry: contract lock, context slices, pre-mortem, claim/evidence verification",
    "LLMCompiler/LATS/ToT/GoT/ReAct/Reflexion: parallel function planning, candidate-plan search, leaf action loops, and repair memory",
    "Theseus VCM: task context slices, constraint capsules, accepted/missed/ignored/failure traces"
  ],
  "hard_constraints": [
    {
      "id": "no_public_benchmark_training",
      "rule": "Public benchmark prompts, tests, hidden tests, solutions, traces, and answer templates are calibration-only and must not enter training rows."
    },
    {
      "id": "no_arbitrary_remote_execution",
      "rule": "Remote work must route only through registered Hive task kinds and existing executor surfaces."
    },
    {
      "id": "no_fallback_returns",
      "rule": "Fallback returns are not valid capability evidence or generated answers."
    },
    {
      "id": "registry_first",
      "rule": "Every compiled goal must name a registered owner surface or be blocked before execution."
    },
    {
      "id": "vcm_context_required",
      "rule": "Every executable plan node must carry a minimal VCM context slice and constraint capsules."
    },
    {
      "id": "teacher_proposal_only",
      "rule": "Teacher use is architecture/curriculum proposal only unless governed distillation gates explicitly admit retained rows."
    }
  ],
  "allowed_executor_backends": [
    "theseus_control_plane",
    "hive_work_board_executor",
    "autonomy_watchdog",
    "vcm_task_context_bridge",
    "local_deterministic_tool",
    "governed_teacher_proposal",
    "planning_benchmark_adapter"
  ],
  "allowed_tools": [
    "python_script",
    "json_report",
    "sqlite_work_board",
    "registry_lookup",
    "vcm_lookup",
    "local_filesystem_read",
    "local_filesystem_write_reports",
    "py_compile",
    "bash_syntax_check",
    "teacher_proposal",
    "benchmark_adapter_dry_run",
    "math.sympy_exact",
    "math.numeric_interval",
    "math.linear_algebra",
    "math.numeric_verify",
    "math.mpmath_verify",
    "logic.lean_check",
    "logic.z3_smt",
    "rewrite.egraph_minimal",
    "rewrite.equality_saturation",
    "search.local_bm25",
    "search.local_hybrid",
    "search.vcm_hybrid",
    "tool.trace_replay"
  ],
  "worker_tiers": {
    "T0": "deterministic local tools, parsers, linters, report readers, schema checks",
    "T1": "local script runners and small deterministic transforms",
    "T2": "local learned systems or accelerator-backed work such as MLX/CUDA/CPU training lanes",
    "T3": "governed teacher proposal mode for architecture/curriculum diagnosis",
    "T4": "run-registry check for public calibration, plus explicit review for risky updates or policy changes"
  },
  "vcm_family_defaults": {
    "planning": "autonomy_governance",
    "code_transfer": "code_generation",
    "memory": "memory_context",
    "hive": "hive_operations",
    "operator": "operator_chat",
    "acceleration": "runtime_accelerator_routing",
    "benchmark": "public_calibration_review"
  },
  "representative_goals": [
    {
      "id": "plan_compiler_bootstrap",
      "title": "Make planning a registry-owned compiled control surface",
      "owner_surface": "core_control_plane",
      "priority": "critical",
      "risk_tier": "medium",
      "objective": "Install the planning compiler as the canonical way Theseus converts objectives into auditable execution graphs.",
      "non_goals": [
        "Do not create a separate autonomous executor.",
        "Do not add a dashboard or mobile surface.",
        "Do not change public calibration policy."
      ],
      "outputs": [
        "reports/theseus_plan_compiler.json",
        "reports/theseus_plan_compiled_dags.json",
        "reports/theseus_plan_trace_bundle.jsonl"
      ],
      "acceptance_tests": [
        "plan_contract_lints_green",
        "registry_owner_surface_present",
        "vcm_context_attached_to_all_nodes",
        "executor_backend_is_existing_surface",
        "trace_bundle_replay_links_present"
      ],
      "atoms": [
        {
          "id": "observe_current_state",
          "op": "OBSERVE",
          "title": "Load registry, control-plane, VCM, work-board, and resource reports",
          "depends_on": [],
          "outputs": ["current_state_snapshot"],
          "required_capabilities": ["registry_lookup", "vcm_lookup", "report_reading"],
          "allowed_tools": ["json_report", "registry_lookup", "vcm_lookup"],
          "executor_backend": "local_deterministic_tool",
          "worker_tier": "T0",
          "estimated_seconds": 8,
          "vcm_family": "planning",
          "acceptance_refs": ["registry_owner_surface_present"]
        },
        {
          "id": "compile_plan_ir",
          "op": "COMPILE",
          "title": "Compile goal contract into typed semantic IR nodes",
          "depends_on": ["observe_current_state"],
          "outputs": ["semantic_ir_dag"],
          "required_capabilities": ["semantic_ir", "dependency_graph"],
          "allowed_tools": ["python_script", "json_report"],
          "executor_backend": "theseus_control_plane",
          "worker_tier": "T0",
          "estimated_seconds": 12,
          "vcm_family": "planning",
          "acceptance_refs": ["plan_contract_lints_green"]
        },
        {
          "id": "attach_context_and_routes",
          "op": "ROUTE",
          "title": "Attach VCM context slices and existing executor targets",
          "depends_on": ["compile_plan_ir"],
          "outputs": ["routed_execution_dag"],
          "required_capabilities": ["vcm_context", "work_board_routing"],
          "allowed_tools": ["vcm_lookup", "json_report", "sqlite_work_board"],
          "executor_backend": "hive_work_board_executor",
          "worker_tier": "T0",
          "estimated_seconds": 10,
          "vcm_family": "planning",
          "acceptance_refs": ["vcm_context_attached_to_all_nodes", "executor_backend_is_existing_surface"]
        },
        {
          "id": "verify_traceability",
          "op": "VERIFY",
          "title": "Verify every node has inputs, outputs, evidence target, and replay link",
          "depends_on": ["attach_context_and_routes"],
          "outputs": ["trace_bundle"],
          "required_capabilities": ["trace_validation", "claim_evidence_mapping"],
          "allowed_tools": ["python_script", "json_report"],
          "executor_backend": "autonomy_watchdog",
          "worker_tier": "T0",
          "estimated_seconds": 10,
          "vcm_family": "planning",
          "acceptance_refs": ["trace_bundle_replay_links_present"]
        }
      ]
    },
    {
      "id": "private_semantic_quality_loop",
      "title": "Improve semantic candidate quality without public-data training",
      "owner_surface": "neural_seed_and_decoder",
      "priority": "high",
      "risk_tier": "medium",
      "objective": "Route semantic candidate-quality repair through plan-aware private residual work before any public calibration.",
      "non_goals": [
        "Do not train on public benchmark artifacts.",
        "Do not count template renderers or fallback returns as capability evidence."
      ],
      "outputs": ["private_residual_repair_plan", "candidate_quality_trace"],
      "acceptance_tests": [
        "private_only_training_surface",
        "no_fallback_returns",
        "failure_categories_mapped_to_plan_nodes",
        "teacher_only_architecture_proposal"
      ],
      "atoms": [
        {
          "id": "mine_residual_categories",
          "op": "OBSERVE",
          "title": "Mine algorithm, return-shape, verifier-contract, and selector/ranking residual categories",
          "depends_on": [],
          "outputs": ["residual_category_manifest"],
          "required_capabilities": ["code_transfer_residuals", "report_reading"],
          "allowed_tools": ["python_script", "json_report"],
          "executor_backend": "local_deterministic_tool",
          "worker_tier": "T0",
          "estimated_seconds": 40,
          "vcm_family": "code_transfer",
          "acceptance_refs": ["failure_categories_mapped_to_plan_nodes"]
        },
        {
          "id": "compile_private_repair_work",
          "op": "COMPILE",
          "title": "Compile residual categories into private-only repair tasks",
          "depends_on": ["mine_residual_categories"],
          "outputs": ["private_repair_dag"],
          "required_capabilities": ["semantic_ir", "private_curriculum"],
          "allowed_tools": ["python_script", "json_report"],
          "executor_backend": "hive_work_board_executor",
          "worker_tier": "T1",
          "estimated_seconds": 120,
          "vcm_family": "code_transfer",
          "acceptance_refs": ["private_only_training_surface"]
        },
        {
          "id": "teacher_architecture_packet",
          "op": "PROPOSE",
          "title": "Package repeated residual failures for governed teacher architecture diagnosis only",
          "depends_on": ["compile_private_repair_work"],
          "outputs": ["teacher_architecture_proposal_packet"],
          "required_capabilities": ["teacher_proposal"],
          "allowed_tools": ["teacher_proposal", "json_report"],
          "executor_backend": "governed_teacher_proposal",
          "worker_tier": "T3",
          "estimated_seconds": 180,
          "vcm_family": "code_transfer",
          "acceptance_refs": ["teacher_only_architecture_proposal"]
        }
      ]
    },
    {
      "id": "vcm_daily_use_planning_loop",
      "title": "Make VCM the default planning memory for daily-use tasks",
      "owner_surface": "vcm_memory",
      "priority": "high",
      "risk_tier": "low",
      "objective": "Attach VCM context slices, constraint capsules, and accepted/missed/ignored traces to every daily-use plan.",
      "non_goals": [
