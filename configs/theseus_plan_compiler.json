          "required_capabilities": ["event_trace", "privacy_policy"],
          "allowed_tools": ["json_report", "local_filesystem_write_reports"],
          "executor_backend": "theseus_control_plane",
          "worker_tier": "T0",
          "estimated_seconds": 20,
          "vcm_family": "operator",
          "acceptance_refs": ["accepted_missed_ignored_trace_shape_present", "raw_private_text_disabled_by_default"]
        }
      ]
    },
    {
