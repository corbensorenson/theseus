      ],
      "artifact_globs": [
        "reports/transfer_artifacts/minecraft_policy_prior_*.json",
        "reports/minecraft_traces/*.jsonl"
      ],
      "load_policy": "on_demand_when_minecraft_frontier_or_user_task",
      "unload_policy": "after_task_boundary_keep_trace_summary"
    },
