{
  "policy": "project_theseus_arm_sucker_policy_v0",
  "purpose": "Keep high-transfer capability in arms and low-transfer specialization in loadable suckers attached to those arms.",
  "terms": {
    "arm": "High-transfer specialist core with reusable state, tools, schemas, permissions, and benchmarks.",
    "sucker": "Low-transfer attachment mounted on an arm or another sucker for a specific game, simulator, benchmark family, runtime, or local asset contract.",
    "nested_sucker": "A sucker that inherits from a broader sucker before adding a narrower specialization."
  },
  "rules": {
    "prefer_sucker_before_new_arm": true,
    "create_new_arm_when": [
      "permission envelope differs materially",
      "runtime substrate differs materially",
      "shared transfer primitives are stable across multiple suckers",
      "sucker count or bloat exceeds parent arm cap"
    ],
    "create_new_sucker_when": [
      "task needs a new adapter, controller prior, action schema, or local asset contract",
      "skill is expected to transfer mostly within one parent arm",
      "the parent arm already has reusable primitives for the task"
    ],
    "sucker_graduation": "A sucker may be promoted into an arm only after repeated transfer to sibling suckers and distinct permission/runtime needs.",
    "external_inference": "forbidden outside sparse teacher governance"
  },
  "cores": [
    {
      "arm_name": "video_game_play_arm",
      "transfer_role": "high",
      "shared_skills": [
        "pixel and low-dimensional observation normalization",
        "action schema mapping",
        "reward and done normalization",
        "episode trace export",
        "state-action-reward-done replay",
        "curriculum and residual escrow for game tasks",
        "controller prior loading"
      ],
      "sucker_cap": 24,
      "permission_domain": "game_control",
      "loads_with": [
        "benchmark_ratchet_arm",
        "puffer_ocean_control_arm",
        "context_packet_memory_arm",
        "safety_reflex_arm"
      ]
    },
    {
      "arm_name": "drone_racing_control_arm",
      "transfer_role": "high",
      "shared_skills": [
        "simulator-first control",
        "state normalization",
        "action scaling",
        "waypoint and racing-line residuals",
        "safety reflex gating",
        "trace export"
      ],
      "sucker_cap": 16,
      "permission_domain": "drone_control",
      "loads_with": [
        "python_runtime_compliance_arm",
        "safety_reflex_arm",
        "rust_cuda_systems_arm"
      ]
    }
  ],
  "suckers": [
