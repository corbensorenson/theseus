      "transfer_role": "medium",
      "frontier_families": [
        "minecraft_rl"
      ],
      "routing_keywords": [
        "minecraft",
        "mineflayer",
        "minedojo",
        "malmo",
        "minerl",
        "crafter",
        "craftax",
        "open world",
